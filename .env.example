# Source: GitHub
GITHUB_PERSONAL_ACCESS_TOKEN=

# Cron (generate a random secret: openssl rand -hex 32)
CRON_SECRET=

# Allowlist — comma-separated emails allowed to sign in
ALLOWED_SIGNUP_EMAILS=

# Sentry (deferred to Section 6)
SENTRY_DSN=

# Email (Resend — deferred to Section 6)
RESEND_API_KEY=
